# ─────────────────────────────────────────────────────────────────────────────
# Cartola FC — Sistema Inteligente | Variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o .env no git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Twitter / X API v2 ────────────────────────────────────────────────────────
# Obtenha em: https://developer.twitter.com/en/portal/dashboard
# O plano gratuito (Essential) permite busca dos últimos 7 dias, 500k tweets/mês.
TWITTER_BEARER_TOKEN=seu_bearer_token_aqui

# ── Opcional: Reddit API (para volumes maiores que a API pública permite) ─────
# Obtenha em: https://www.reddit.com/prefs/apps  (tipo: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CartolaAnalyzer/2.0

# ── Opcional: controle de comportamento ──────────────────────────────────────
# Forçar modo de análise: auto | bert | vader
SENTIMENT_MODE=auto

# Usar GPU para BERT (0 = primeira GPU, -1 = CPU)
BERT_DEVICE=-1
